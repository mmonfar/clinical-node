# Copy this file to .env and fill in your own values.
# Never commit .env to version control.

# OpenAI API key — required for all LLM agents
OPENAI_API_KEY=sk-proj-...

# NCBI / PubMed credentials — required for evidence search
# Register at: https://www.ncbi.nlm.nih.gov/account/
ENTREZ_EMAIL=you@example.com
ENTREZ_API_KEY=your_ncbi_api_key_here

# Aliases used internally (keep in sync with the values above)
EMAIL_FOR_PUBMED=you@example.com
NCBI_API_KEY=your_ncbi_api_key_here
